@model List<ServiceLocator.Models.NotificationViewModel>
@{
    bool viewerIsCustomer = Context.Session.GetInt32("CustomerId") != null;
    ViewData["Title"] = "Notifications";
}

<body class="homepage-background">

    <div style="background-color:#00ccd7; color:#f0f0f0; text-align:center; padding: 30px 0; font-size:40px; font-weight:600;">
        Notifications
    </div>

    <div style="width: 800px; max-height: 70vh; margin: 50px auto; background-color:#ccc; border-radius:10px; padding:20px; overflow-y:auto;">
        @if (!Model.Any())
        {
            <p style="text-align:center; color:black;">No notifications</p>
        }
        else
        {
            @foreach (var n in Model)
            {
                <div style="border:1px solid #aaa; padding:10px; margin-bottom:10px; background-color:#eee; border-radius:5px;">

                    @* SERVICE OFFER — ONLY BEFORE ACCEPTANCE *@
                    @if (!n.IsAccepted)
                    {
                        <p>
                            @if (viewerIsCustomer)
                            {
                                <text>Provider @n.InitiatorName is offering their @n.Service services.</text>
                            }
                            else
                            {
                                <text>Customer @n.InitiatorName is requesting your @n.Service services.</text>
                            }
                        </p>

                        <form asp-action="AcceptNotification" method="post" class="d-inline">
                            <input type="hidden" name="notificationId" value="@n.NotificationId" />
                            <button type="submit" class="btn btn-primary">Accept</button>
                        </form>
                    }
                    else
                    {
                        @* ACCEPTED → CONVERSATION MODE *@
                        <p style="color: green; font-weight: 600;">
                            ✔ You can contact @n.InitiatorName at @n.Phone or @n.Email
                        </p>

                        <!-- MESSAGING FORM -->
                        <form class="message-form"
                              data-recipient-id="@n.InitiatorId"
                              data-recipient-type="@((viewerIsCustomer) ? "Provider" : "Customer")">
                            <textarea class="form-control mb-2" placeholder="Type your message..." rows="2"></textarea>
                            <button type="submit" class="btn btn-success btn-sm">Send</button>
                            <span class="text-success ms-2 message-status" style="display:none;">✔ Message sent</span>
                        </form>

                        <!-- DISPLAY MESSAGES -->
                        <div class="messages-list mt-2">
                            @foreach (var msg in n.Messages ?? new List<ServiceLocator.Models.MessageViewModel>())
                            {
                                <div style="border-top:1px dashed #aaa; padding:3px;">
                                    <strong>@msg.SenderName:</strong> @msg.Text
                                </div>
                            }
                        </div>
                    }
                </div>
            }
        }
    </div>

    <div class="container mt-4">
        <div class="row justify-content-center gap-2">
            <button onclick="goBack()" class="btn btn-primary col-auto">Back</button>
            <script>
                function goBack() {
                    window.history.back();
                }
            </script>
            <a asp-action="Index" class="btn btn-primary col-auto">Homepage</a>
        </div>
    </div>

    <script>
        document.querySelectorAll(".message-form").forEach(form => {
            form.addEventListener("submit", function(e){
                e.preventDefault();
                const textarea = this.querySelector("textarea");
                const message = textarea.value.trim();
                if(!message) return;

                const recipientId = this.dataset.recipientId;
                const recipientType = this.dataset.recipientType;
                const status = this.querySelector(".message-status");

                fetch("/Home/SendMessage", {
                    method: "POST",
                    headers: {"Content-Type":"application/x-www-form-urlencoded"},
                    body: `recipientId=${recipientId}&recipientType=${recipientType}&messageText=${encodeURIComponent(message)}`
                })
                .then(res => {
                    if(res.ok){
                        status.style.display = "inline";
                        textarea.value = "";
                    } else {
                        alert("Message failed");
                    }
                })
            });
        });
    </script>

</body>
